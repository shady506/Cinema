@model Movies

<div class="container my-5">
    <div class="card shadow-lg">
        <div class="row g-0">
            <!-- Movie Poster -->
            <div class="col-md-4">
                <img src="~/images/movies/@Model.ImgUrl" 
                     alt="@Model.Name" 
                     class="img-fluid rounded-start" 
                     style="height:100%; object-fit:cover;">
            </div>

            <!-- Movie Info -->
            <div class="col-md-8">
                <div class="card-body">
                    <h2 class="card-title text-primary mb-3">@Model.Name</h2>

                    <!-- Status Badge -->
                    <p>
                        <strong>Status:</strong>
                        @if (DateTime.Now >= Model.StartDate && DateTime.Now <= Model.EndDate)
                        {
                            <span class="badge bg-success">Available 🎟</span>
                        }
                        else if (DateTime.Now < Model.StartDate)
                        {
                            <span class="badge bg-warning text-dark">Upcoming ⏳</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Expired ❌</span>
                        }
                    </p>

                    <!-- Description -->
                    <p class="card-text">
                        <strong>Description:</strong><br />
                        @Model.Description
                    </p>

                    <!-- Movie Details -->
                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item"><strong>Price:</strong> @Model.Price $</li>
                        <li class="list-group-item"><strong>Start Date:</strong> @Model.StartDate</li>
                        <li class="list-group-item"><strong>End Date:</strong> @Model.EndDate</li>
                        <li class="list-group-item"><strong>Category:</strong> @Model.Category.Name</li>
                        <li class="list-group-item"><strong>Cinema:</strong> @Model.Cinema.Name</li>
                    </ul>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">
                            ⬅ Back to Movies
                        </a>
                        <button class="btn btn-primary">🎟 Book Ticket</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
