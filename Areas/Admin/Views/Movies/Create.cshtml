@model CategoriesWithCinemasVM


<div class="container">
    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input type="text" class="form-control" id="name" name="Name">
                    <span class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <div class="form-floating">
                        <textarea class="form-control" placeholder="Leave a description here" id="description" style="height: 100px" name="Description"></textarea>
                        <label for="description">You Description Here...</label>
                    </div>
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="ImgUrl" class="form-label">Movie Image</label>
                    <input type="file" class="form-control" id="ImgUrl" name="ImgUrl" accept="image/*" onchange="previewImage(event)">
                    <img id="preview" src="#" alt="Image Preview" class="img-thumbnail mt-2" style="max-width: 200px; display: none;" />
                </div>

                <div class="mb-3">
                    <label for="Price" class="form-label">Price</label>
                    <input type="number" class="form-control" id="Price" name="Price">
                </div>

                <div class="mb-3">
                    <label for="Price" class="form-label">StartDate</label>
                    <input type="datetime-local" class="form-control" id="StartDate" name="StartDate">
                </div>

                <div class="mb-3">
                    <label for="Price" class="form-label">EndDate</label>
                    <input type="datetime-local" class="form-control" id="EndDate" name="EndDate">
                </div>

                <div class="mb-3">
                    <label for="CategoryId" class="form-label">Category Name</label>
                    <select class="form-select" name="CategoryId">
                        @foreach (var item in Model.Categories)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }

                    </select>
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="CinemaId" class="form-label">Cineama Name</label>
                    <select class="form-select" name="CinemaId">
                        @foreach (var item in Model.Cinemas)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }

                    </select>
                    <span class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = "block";
            };

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

