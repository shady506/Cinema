@model CategoriesWithCinemasVM


<div class="container">
    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input type="text" class="form-control" id="name" name="Name" value="@Model.Movie.Name">
                    <span class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <div class="form-floating">
                        <textarea class="form-control" placeholder="Leave a description here" id="description" style="height: 100px" name="Description">@Model.Movie.Description</textarea>
                        <label for="description">You Description Here...</label>
                    </div>
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="MainImg" class="form-label">Product Image</label>
                    <input type="file" class="form-control" id="MainImg" name="MainImg" accept="image/*" onchange="previewImage(event)">

                    <!-- Show existing image if available -->
                    <img id="preview"
                         src="~/Images/@Model.Movie.ImgUrl"
                         alt="Image Preview"
                         class="img-thumbnail mt-2"
                         style="max-width: 200px; @(string.IsNullOrEmpty(Model.Movie.ImgUrl) ? "display:none;" : "")" />
                </div>

                <div class="mb-3">
                    <label for="Price" class="form-label">Price</label>
                    <input type="number" class="form-control" id="Price" name="Price" value="@Model.Movie.Price">
                </div>

                <div class="mb-3">
                    <label for="StartDate" class="form-label">StartDate</label>
                    <input type="datetime-local" class="form-control" id="StartDate" name="StartDate" value="@Model.Movie.StartDate">
                </div>

                <div class="mb-3">
                    <label for="EndDate" class="form-label">EndDate</label>
                    <input type="datetime-local" class="form-control" id="EndDate" name="EndDate" value="@Model.Movie.EndDate">
                </div>

                <div class="mb-3">
                    <label for="CategoryId" class="form-label">Category Name </label>
                    <select class="form-select" name="CategoryId">
                        @foreach (var item in Model.Categories)
                        {
                            if (Model.Movie.CategoryId == item.Id)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }

                    </select>
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="CinemaId" class="form-label">Cinema Name</label>
                    <select class="form-select" name="CinemaId">
                        @foreach (var item in Model.Cinemas)
                        {
                            if (Model.Movie.CinemaId== item.Id)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        }

                    </select>
                    <span class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="status" class="form-label">Status</label>

                    <span class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = "block";
            };

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
